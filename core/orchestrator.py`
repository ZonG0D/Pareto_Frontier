# Ensure project root is in the path for modular imports
PROJECT_ROOT = str(Path(__file__).resolve().parent.parent)
if PROJECT_ROOT not in sys.path:
    sys.path.append(PROJECT_ROOT)


def sanitize_text(text: str) -> str:
    """Cleans input text by removing non-printable characters and normalizing whitespace."""
    if not isinstance(text, str):
        return ""
    text = "".join(char for char in text if char.isprintable() or char in "\n\r")
    return " ".join(text.split())


def log_info(msg: str):
    print(f"[INFO] {msg}", file=sys.stderr)


def log_trace(msg: str):
    print(f"[TRACE] {msg}", file=sys.stderr)


def log_decision(msg: str):
    print(f"[DECISION] {msg}", file=sys.stderr)


def log_metric(msg: str):
    print(f"[METRIC] {msg}", file=sys.stderr)


def log_warn(msg: str):
    print(f"[WARN] {msg}", file=sys.stderr)


def log_error(msg: str, fatal: bool = False):
    prefix = "[ERROR]" if fatal else "[INFO]"  # Standardizing on error/info prefixing as per protocol
    print(f"{prefix} {msg}", file=sys.stderr)


class Orchestrator:
    def __init__(self, config_path: Optional[Path] = None):
        self.base_dir = Path(__file__).resolve().parent.parent
        if config_path is None:
            config_path = self.base_dir / "models" / "config.yaml"
        else:
            config_path = Path(config_path)
            if not config_path.is_absolute():
                config_path = self.base_dir / config_path

        try:
            with open(config_path, 'r') as f:
                raw_cfg = yaml.safe_load(f)
                self.config = FullConfig(**raw_cfg)
        except Exception as e:
            print(f"[ERROR] Failed to load configuration from {config_path}: {e}", file=sys.stderr)
            sys.exit(1)

        self.text_cache = TextCache(str(self.base_dir / ".cache" / "text_cache"))
        self.stabilizer = CascadeStabilizer()


    def _run_parse_cascade(self, text: str):
        try:
            cheap_tier = self.config.tiers.cheap
            endpoint = cheap_tier.endpoint if cheap_tier.endpoint.startswith('http') else f"http://{cheap_tier.endpoint}"
            if not endpoint.endswith('/api/chat'):
                endpoint = endpoint.rstrip('/') + '/api/chat'

            parser = InputParser(endpoint=endpoint, model=cheap_tier.model)
            return parser.parse_via_ollama(text)
        except Exception as e:
            print(f"[ERROR] Error during parsing stage: {e}", file=sys.stderr)
            return None


    def _run_smart_model(self, text: str, protocol: Optional[str] = None) -> tuple[str, int]:
        tier = self.config.tiers.smart
        endpoint = tier.endpoint if tier.endpoint.startswith('http') else f"http://{tier.endpoint}"
        if not endpoint.endswith('/api/chat'):
            endpoint = endpoint.rstrip('/') + '/api/chat'

        skeleton_context = ""
        try:
            from core.runtime.skeletonizer import SkeletonGenerator
            skeleton_gen = SkeletonGenerator(model=self.config.tiers.cheap.model) 
            skeleton = skeleton_gen.generate_skeleton(text)
            if skeleton:
                skeleton_context = f"\n[STRUCTURED SKELETON TO FOLLOW:\n{skeleton}\n]\n"
                log_decision("Skeleton prediction acquired from Cheap Tier. Injecting into Smart Tier.")
        except Exception as e:
            log_warn(f"Skeleton generation skipped/failed: {e}")

        augmented_prompt = text + skeleton_context
        if protocol:
            augmented_prompt += f"\nPROTOCOL:\n{protocol}"

        def smart_api_call():
            payload = {
                "model": tier.model, 
                "messages": [{"role": "user", "content": augmented_prompt}], 
                "stream": False
            }
            response = requests.post(endpoint, json=payload, timeout=tier.timeout)
            response.raise_for_status()
            res_json = response.json()
            
            content = ""
            if 'message' in res_json: 
                content = res_json['message']['content']
            elif 'choices' in res_json: 
                content = res_json['choices'][0]['message']['content']
            else: 
                content = str(res_json)

            prompt_tokens = res_json.get('prompt_eval_count', 0)
            response_tokens = res_json.get('eval_count', 0)
            total_tokens = prompt_tokens + response_tokens
            return sanitize_text(content), total_tokens

        fallback_msg = f"Error: Smart tier unavailable at {endpoint}"
        captured_tokens = [0]

        def wrapped_for_stabilizer():
            try:
                res_text, tokens = smart_api_call()
                captured_tokens[0] = tokens
                return res_text
            except Exception as e:
                print(f"[ERROR] Smart tier exception: {e}", file=sys.stderr)
                raise e

        reasoning_text = self.stabilizer.wrap_smart_model(wrapped_for_stabilizer, fallback_text=fallback_msg)
        return reasoning_text, captured_tokens[0]


    def run_cascade(self, user_input: str):
        import time
        from datetime import datetime
        audit_log = self.base_dir / "evals" / "performance_audit.jsonl"
        metrics_engine = MetricsEngine(audit_log)
        
        start_time = time.perf_counter()
        metrics = {"stages": [], "total_latency_ms": 0, "cache_hit": False}
        log_info(f"Initiating Cascade for input: '{user_input[:50]}...'")

        # --- STAGE 1: Text Cache (Pattern Identification / Intent Discovery) --
        stage_start = time.perf_counter()
        match = self.text_cache.find_best_match(user_input)
        stage_duration = (time.perf_counter() - stage_start) * 1000

        parsed_json = {"cleaned_text": user_input, "semantic_helper": "", "cache_hit": False}
        lego_protocol = None

        if match:
            log_decision(f"Pattern Matched in Cache (Match type: {match['similarity']})")
            metrics["cache_hit"] = True
            parsed_json["semantic_helper"] = match['response'].get('semantic_helper', 'default')
            parsed_json["cache_hit"] = True
        else:
            log_trace("No exact pattern matched in TextCache.")

        metrics["stages"].append({
            "name": "pattern_match", 
            "latency_ms": round(stage_duration, 2), 
            "cached": match is not None
        })

        # --- STAGE 2: Parsing & Intent Refinement (Cheap Tier) --
        if not match:
            stage_start = time.perf_counter()
            parsed_json = self._run_parse_cascade(user_input)
            if not parsed_json:
                log_error("Parsing stage failed.", fatal=True)
                raise Exception("Failed to get a valid response from parsing.")

            if parsed_json.get('cache_hit', False):
                 metrics["cache_hit"] = True
            
            stage_duration = (time.perf_counter() - stage_start) * 1000
            metrics["stages"].append({
                "name": "parsing", 
                "latency_ms": round(stage_duration, 2), 
                "cached": parsed_json.get('cache_hit', False)
            })

        cleaned_text = parsed_json.get("cleaned_text", user_input)
        semantic_intent = parsed_json.get("semantic_helper", "")
        log_trace(f"Normalized Text: {cleaned_text}")
        log_trace(f"Semantic Intent Identified: {semantic_intent}")

        # --- STAGE 3: Smart Reasoning Tier with Lego Injection (The Synthesis Stage) --
        stage_start = time.perf_counter()
        
        if semantic_intent and semantic_intent not in ["default", "Parsed"]:
            lego_file = self.base_dir / "core" / "legos" / f"{semantic_intent}.md"
            if lego_file.exists():
                try:
                    with open(lego_file, 'r') as f:
                        lego_protocol = f.read().strip()
                    log_decision(f"Lego Injected: {semantic_intent}")
                except Exception as e:
                    log_warn(f"Failed to read lego file {lego_file}: {e}")

        log_decision("Escalating to Smart Tier for dynamic synthesis...")
        reasoning_result, response_tokens = self._run_smart_model(cleaned_text, protocol=lego_protocol)
        stage_duration = (time.perf_counter() - stage_start) * 1000
        metrics["stages"].append({
            "name": "reasoning", 
            "latency_ms": round(stage_duration, 2), 
        })

        total_duration = (time.perf_counter() - start_time) * 1000
        metrics["total_latency_ms"] = round(total_duration, 3)
        
        is_error = any(err in reasoning_result.lower() for err in ["error", "unavailable", "failed"])
        accuracy = 0.95 if (not is_error and len(reasoning_result) > 10) else 0.0
        
        if not is_error and cleaned_text:
            self.text_cache.add_entry(user_input, {
                "resp": reasoning_result, 
                "parsed": parsed_json, 
                "semantic_helper": semantic_intent
            })

        # Real Cost Calculation using Token Count + Config Pricing
        tier = self.config.tiers.smart
        price_per_1k = getattr(tier, 'price_per_1k_tokens', 0.0)
        cost = (response_tokens / 1000.0) * price_per_1k
        metrics["total_cost"] = round(cost, 6)

        # Log to metrics engine!
        try:
            metrics_engine.log_execution(
                prompt=user_input[:50], 
                accuracy=accuracy, 
                cost=cost, 
                latency=round(total_duration/1000, 2), 
                cache_hit=match is not None or parsed_json.get('cache_hit', False)
            )
        except Exception as e:
            log_warn(f"Failed to log metrics: {e}")

        log_metric(f"Total Latency: {round(total_duration/1000, 3)}s | Cost: ${metrics['total_cost']:.4f}")

        return {
            "original": user_input,
            "parsed": parsed_json,
            "reasoning": reasoning_result,
            "_metrics": metrics,
            "_accuracy": accuracy,
            "_tokens": response_tokens,
            "_cost": cost
        }


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("prompt", nargs='*', help="The prompt to process.")
    args = parser.parse_args()
    if not args.prompt: 
        sys.exit(1)

    orch = Orchestrator()
    try: 
        result = orch.run_cascade(" ".join(args.prompt))
        print(json.dumps(result, indent=2))
    except Exception as e: 
        log_error(f"FATAL EXECUTION ERROR: {e}", fatal=True); sys.exit(1)
