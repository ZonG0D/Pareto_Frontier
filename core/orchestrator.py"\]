def sanitize_text(text: str) -> str:
    if not isinstance(text, str): return ""
    # Remove control characters and unprintable whitespace/null bytes
    text = "".join(char for char in text if char.isprintable() or char in "\n\r")
    text = text.replace('\u200b', ' ').replace('\xa0', ' ').replace('\ufeff', ' ').replace('\r', '')
    return " ".join(text.split())

def log_info(msg): print(f"[INFO] {msg}", file=sys.stderr)
def log_trace(msg): print(f"[TRACE] {msg}", file=sys.stderr)
def log_decision(msg): print(f"[DECISION] {msg}", file=sys.stderr)
def log_metric(msg): print(f"[METRIC] {msg}", file=sys.stderr)
def log_warn(msg): print(f"[WARN] {msg}", file=sys.stderr)
def log_error(msg, fatal=False): 
    prefix = "[ERROR]" if fatal else "[INFO]"
    print(f"{prefix} {msg}", file=sys.stderr)

class Orchestrator:
    def __init__(self, config_path=None):
        self.base_dir = Path(__file__).resolve().parent.parent
        if config_path is None:
            config_path = self.base_dir / "models" / "config.yaml"
        else:
            config_path = Path(config_path)
            if not config_path.is_absolute():
                config_path = self.base_dir / config_path
        try:
            with open(config_path, 'r') as f:
                raw_cfg = yaml.safe_load(f)
                self.config = FullConfig(**raw_cfg)
        except Exception as e:
            log_error(f"Failed to load configuration from {config_path}: {e}", fatal=True)
            sys.exit(1)

        self.text_cache = TextCache(str(self.base_dir / ".cache" / "text_cache"))
        self.stabilizer = CascadeStabilizer()

    def _run_parse_cascade(self, text: str):
        try:
            cheap_tier = self.config.tiers.cheap
            endpoint = cheap_tier.endpoint if cheap_tier.endpoint.startswith('http') else f"http://{cheap_tier.endpoint}"
            parser = InputParser(endpoint=endpoint, model=cheap_tier.model)
            return parser.parse_via_ollama(text)
        except Exception as e:
            log_error(f"Error during parsing stage: {e}")
            return None

    def _run_smart_model(self, text: str):
        tier = self.config.tiers.smart
        endpoint = tier.endpoint if tier.endpoint.startswith('http') else f"http://{tier.endpoint}"

        def smart_api_call():
            import requests
            payload = {
                "model": tier.model, 
                "messages": [{"role": "user", "content": text}], 
                "stream": False
            }
            response = requests.post(endpoint, json=payload, timeout=tier.timeout)
            response.raise_for_status()
            res_json = response.json()
            if 'message' in res_json: 
                content = res_json['message']['content']
            elif 'choices' in res_json: 
                content = res_json['choices'][0]['message']['content']
            else: 
                content = str(res_json)
            return sanitize_text(content)

        fallback_msg = f"Error: Smart tier unavailable at {endpoint}"
        return self.stabilizer.wrap_smart_model(lambda: smart_api_call(), fallback_text=fallback_msg)

    def run_cascade(self, user_input: str):
        from datetime import datetime
        audit_log = self.base_dir / "evals" / "performance_audit.jsonl"
        metrics_engine = MetricsEngine(audit_log)

        start_time = time.perf_counter()
        metrics = {"stages": [], "total_latency_ms": 0, "cache_hit": False}
        log_info(f"Initiating Cascade for input: '{user_input[:50]}...'")

        # --- STAGE 1: Text Cache Check (The "Instant" Tier) ---
        stage_start = time.perf_counter()
        match = self.text_cache.find_best_match(user_input)
        stage_duration = (time.perf_counter() - stage_start) * 1000

        if match:
            log_decision(f"Cache HIT detected (Match type: {match['response'].get('match_type', 'exact')})")
            total_duration = (time.perf_counter() - start_time) * 1000
            metrics["cache_hit"] = True
            metrics["stages"].append({
                "name": "text_cache", 
                "latency_ms": round(stage_duration, 2), 
                "cached": True
            })
            return {
                "original": user_input,
                "parsed": match['response'].get('parsed', {"cleaned_text": user_input, "semantic_helper": "Cached result", "cache_hit": True}),
                "reasoning": match['response']['resp'],
                "_metrics": metrics,
                "_accuracy": 1.0,
                "_cost": 0.000001,
            }

        # --- STAGE 2: Parsing & Cache Check (Cheap Tier) ---
        stage_start = time.perf_counter()
        parsed_json = self._run_parse_cascade(user_input)
        stage_duration = (time.perf_counter() - stage_start) * 1000

        if not parsed_json:
            log_error("Parsing/Cache stage failed to produce output.", fatal=True)
            raise Exception("Failed to get a valid response from parsing.")

        is_cache_hit = parsed_json.get('cache_hit', False)
        metrics["cache_hit"] = is_cache_hit
        metrics["stages"].append({
            "name": "parsing", 
            "latency_ms": round(stage_duration, 2), 
            "cached": is_cache_hit
        })

        cleaned_text = parsed_json.get("cleaned_text", user_input)
        semantic_intent = parsed_json.get("semantic_helper", "")
        log_trace(f"Normalized Text: {cleaned_text}")
        log_trace(f"Semantic Intent: {semantic_intent}")

        # --- STAGE 3: Smart Reasoning Tier ---
        stage_start = time.perf_counter()
        log_decision("Escalating to Smart Tier for reasoning...")
        reasoning_result = self._run_smart_model(cleaned_text)
        stage_duration = (time.perf_counter() - stage_start) * 1000
        metrics["stages"].append({
            "name": "reasoning", 
            "latency_ms": round(stage_duration, 2), 
        })

        total_duration = (time.perf_counter() - start_time) * 1000
        metrics["total_latency_ms"] = round(total_duration, 3)
        
        is_error = any(err in reasoning_result.lower() for err in ["error", "unavailable", "failed"])
        accuracy = 0.95 if (not is_error and len(reasoning_result) > 10) else 0.0

        cheap_tier = self.config.tiers.cheap
        smart_tier = self.config.tiers.smart
        parsing_cost = (metrics["stages"][0]["latency_ms"] / 1000) * cheap_tier.unit_cost
        reasoning_cost = (metrics["stages"][1]["latency_ms"] / 1000) * smart_tier.unit_cost
        total_cost = parsing_cost + reasoning_cost

        if is_error:
            log_warn(f"Reasoning error detected: {reasoning_result[:50]}...")

        metrics["total_cost"] = round(total_cost, 6)
        log_metric(f"Total Latency: {round(total_duration/1000, 3)}s | Total Cost Score: {round(total_cost, 4)}")

        if not is_error and cleaned_text:
            self.text_cache.add_entry(user_input, {"resp": reasoning_result, "parsed": parsed_json, "semantic_helper": semantic_intent})

        metrics_engine.log_execution(user_input, accuracy, total_cost, total_duration/1000, is_cache_hit)

        return {
            "original": user_input,
            "parsed": parsed_json,
            "reasoning": reasoning_result,
            "_metrics": metrics,
            "_accuracy": accuracy,
            "_cost": total_cost
        }

if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("prompt", nargs='*', help="The prompt to process.")
    args = parser.parse_args()
