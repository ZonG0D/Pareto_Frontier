#!/bin/bash
# Pareto Frontier - CLI Entry Point
# This shim ensures the command is run from the project root for relative path stability.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_ROOT"
VENV_PYTHON="$PROJECT_ROOT/.venv/bin/python3"

if [ ! -f "$VENV_PYTHON" ]; then
    echo "Error: Virtual environment not found at $VENV_PYTHON"
    echo "Please run ./setup.sh from the project root first."
    exit 1
fi

# Run CLI with proper PYTHONPATH to find src/pareto_frontier
cd "$PROJECT_ROOT"
echo "$@" | "$VENV_PYTHON" "$SCRIPT_DIR/pareto_cli.py"