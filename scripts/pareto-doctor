#!/bin/bash
set -e
echo "=== Pareto Frontier Health Check ==="
echo "[*] Checking project structure..."
if [ ! -d "bin" ]; then echo "  ❌ bin: MISSING"; else echo "  ✅ bin: OK"; fi
if [ ! -d "src/pareto_frontier/core" ]; then echo "  ❌ src/pareto_frontier/core: MISSING"; else echo "  ✅ src/pareto_frontier/core: OK"; fi
if [ -f "pyproject.toml" ] || [ -f "setup.py" ]; then echo "  ✅ Python project structure: OK"; else echo "  ❌ pyproject.toml/setup.py: MISSING"; fi
echo "[*] Setup complete. To use Pareto Frontier:"
echo "  1. ./scripts/setup-env.sh"
echo "  2. source .venv/bin/activate"
echo "  3. bin/pareto-run \"your prompt here\""
